<#CoolingCoilMapping>
    rml:logicalSource [
        rml:source "placeholder.json";
        rml:referenceFormulation ql:JSONPath;
        rml:iterator "$[?(@.type=='CoolingCoil')]"
    ];
    rml:logicalSource [
        rml:source "placeholder.json";
        rml:referenceFormulation ql:JSONPath;
        rml:iterator "$[?(@.type=='CoolingCoil')]"
    ];
        rml:source "placeholder.json";
        rml:referenceFormulation ql:JSONPath;
        rml:iterator "$[?(@.type=='CoolingCoil')]"
    ];
        rml:referenceFormulation ql:JSONPath;
        rml:iterator "$[?(@.type=='CoolingCoil')]"
    ];
        rml:iterator "$[?(@.type=='CoolingCoil')]"
    ];
    ];
    rr:subjectMap [
        rr:template "http://example.com/CoolingCoil/{id}";
        rr:class brick:BRICK_COOLINGCOIL_CLASS
